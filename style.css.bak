:root {
    --bg: #000;
    --card: #121212;
    --accent: #1DB954;
    --text: #fff;
    --dim: #a7a7a7;
    --red: #e91429;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; padding-bottom: 90px; }

.hdr { padding: 20px; border-bottom: 1px solid #282828; display: flex; justify-content: space-between; }
.hdr h1 { font-size: 1.1rem; font-weight: 800; }
.lbl { font-size: 0.65rem; text-transform: uppercase; color: var(--dim); margin: 20px; letter-spacing: 1px; }

.page { display: none; padding: 0 15px; }
.page.active { display: block; animation: fadeIn 0.3s; }

/* Dashboard Card */
.bal-card { background: var(--card); border-radius: 15px; margin: 10px; padding: 20px; }
.bal-section { text-align: center; padding: 10px 0; }
.bal-section h2 { font-size: 2.8rem; margin-bottom: 10px; font-weight: 800; }
.divider { height: 1px; background: #282828; margin: 15px 0; }

/* Grid Membri */
.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 0 5px; }
.mem-card { background: var(--card); padding: 15px; border-radius: 12px; border: 1px solid #282828; }
.status { font-size: 0.7rem; display: block; margin: 5px 0 15px; }

/* Bottoni */
button {
    background: #282828; color: white; border: none; padding: 12px;
    border-radius: 25px; font-weight: 600; cursor: pointer; transition: 0.2s;
}
.btn-sm { padding: 6px 15px; font-size: 0.8rem; }
.btn-accent { background: var(--accent); color: black; }
.btn-danger { background: var(--red); width: 15%; }
.btn-close { background: transparent; color: var(--dim); margin-top: 10px; }

/* Navigazione */
.nav { position: fixed; bottom: 0; width: 100%; background: #000; display: flex; height: 70px; border-top: 1px solid #282828; }
.nav button { flex: 1; background: transparent; border-radius: 0; font-size: 0.8rem; color: var(--dim); }

/* Modali */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); display: none; align-items: center; justify-content: center; z-index: 100; }
.modal { background: #181818; padding: 30px; border-radius: 20px; width: 90%; max-width: 400px; text-align: center; }
.pkg-select { display: flex; flex-direction: column; gap: 10px; }

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }